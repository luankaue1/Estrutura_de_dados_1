#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct Monstro {
    int id;
    char nome[50];
    struct Monstro *proximo;
} Monstro;

Monstro *inicio = NULL;

void adicionarMonstro(int id, const char *nome) {
    Monstro *novo = (Monstro *)malloc(sizeof(Monstro));
    novo->id = id;
    strcpy(novo->nome, nome);
    novo->proximo = NULL;

    if (inicio == NULL) {
        inicio = novo;
    } else {
        Monstro *atual = inicio;
        while (atual->proximo != NULL) {
            atual = atual->proximo;
        }
        atual->proximo = novo;
    }
}

void ordenarBestiario() {
    if (inicio == NULL) return;

    for (Monstro *i = inicio; i != NULL; i = i->proximo) {
        for (Monstro *j = i->proximo; j != NULL; j = j->proximo) {
            if (i->id > j->id) {
                int tempId = i->id;
                char tempNome[50];
                strcpy(tempNome, i->nome);

                i->id = j->id;
                strcpy(i->nome, j->nome);

                j->id = tempId;
                strcpy(j->nome, tempNome);
            }
        }
    }
}

void mostrarBestiario() {
    Monstro *atual = inicio;
    while (atual != NULL) {
        printf("ID: %d, Nome: %s\n", atual->id, atual->nome);
        atual = atual->proximo;
    }
}

int main() {
    int opcao;

    while (1) {
        printf("Menu:\n");
        printf("1. Adicionar monstro\n");
        printf("2. Ordenar bestiário\n");
        printf("3. Mostrar bestiário\n");
        printf("4. Sair\n");
        printf("Escolha uma opção: ");
        scanf("%d", &opcao);

        switch (opcao) {
            case 1: {
                int id;
                char nome[50];
                printf("Digite o ID e o nome do monstro: ");
                scanf("%d %s", &id, nome);
                adicionarMonstro(id, nome);
                break;
            }
            case 2:
                ordenarBestiario();
                printf("Bestiário ordenado.\n");
                break;
            case 3:
                mostrarBestiario();
                break;
            case 4:
                exit(0);
            default:
                printf("Opção inválida. Tente novamente.\n");
        }
    }

    return 0;
}