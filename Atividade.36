#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int posicao_x;
    int posicao_y;
    int valor;
} Moeda;

int main() {
    int quantidade;
    int total_pontos = 0;

    printf("Quantas moedas existem no nivel? ");
    scanf("%d", &quantidade);

    Moeda *moedas = (Moeda *) malloc(quantidade * sizeof(Moeda));

    if (moedas == NULL) {
        printf("Erro de alocacao de memoria!\n");
        return 1;
    }

    for (int i = 0; i < quantidade; i++) {
        printf("\nMoeda %d:\n", i + 1);
        printf("Posicao X: ");
        scanf("%d", &moedas[i].posicao_x);
        printf("Posicao Y: ");
        scanf("%d", &moedas[i].posicao_y);
        printf("Valor: ");
        scanf("%d", &moedas[i].valor);
    }

    for (int i = 0; i < quantidade; i++) {
        total_pontos += moedas[i].valor;
    }

    printf("\nPontuacao maxima do nivel: %d\n", total_pontos);

    free(moedas);

    return 0;
}
