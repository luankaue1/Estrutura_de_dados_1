#include<stdio.h>
#include<stdlib.h>

typedef struct {
    float pos_x;
    int pontuacao;
    int tem_pulo_duplo;
} Jogador;

int main() {
    Jogador heroi;
    
    heroi.pos_x = 50.0;
    heroi.pontuacao = 0;
    heroi.tem_pulo_duplo = 0;
    
    printf("Inicio da fase! Posicao X: %.1f, Pontos: %d, Pulo Duplo: %s\n",
           heroi.pos_x, heroi.pontuacao, 
           heroi.tem_pulo_duplo == 0 ? "Nao" : "Sim");
    
    heroi.pontuacao += 10;
    heroi.tem_pulo_duplo = 1;
    
    printf("Itens coletados! Posicao X: %.1f, Pontos: %d, Pulo Duplo: %s\n",
           heroi.pos_x, heroi.pontuacao, 
           heroi.tem_pulo_duplo == 0 ? "Nao" : "Sim");
    
    return 0;
}
