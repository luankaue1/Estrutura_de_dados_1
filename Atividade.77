#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int id;
    int pontuacao;
} Jogador;

void swap(Jogador *a, Jogador *b) {
    Jogador temp = *a;
    *a = *b;
    *b = temp;
}

int partition(Jogador *jogadores, int low, int high) {
    int pivot = jogadores[high].pontuacao;
    int i = low - 1;

    for (int j = low; j < high; j++) {
        if (jogadores[j].pontuacao > pivot) {
            i++;
            swap(&jogadores[i], &jogadores[j]);
        }
    }
    swap(&jogadores[i + 1], &jogadores[high]);
    return i + 1;
}

void quickSort(Jogador *jogadores, int low, int high) {
    if (low < high) {
        int pi = partition(jogadores, low, high);
        quickSort(jogadores, low, pi - 1);
        quickSort(jogadores, pi + 1, high);
    }
}

int main() {
    int n;

    printf("Digite o número de jogadores: ");
    scanf("%d", &n);
    Jogador *jogadores = (Jogador *)malloc(n * sizeof(Jogador));

    for (int i = 0; i < n; i++) {
        printf("Digite o ID e a pontuação do jogador %d: ", i + 1);
        scanf("%d %d", &jogadores[i].id, &jogadores[i].pontuacao);
    }

    quickSort(jogadores, 0, n - 1);

    printf("Jogadores ordenados por pontuação:\n");
    for (int i = 0; i < n; i++) {
        printf("ID: %d, Pontuação: %d\n", jogadores[i].id, jogadores[i].pontuacao);
    }

    free(jogadores);
    return 0;
}