#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;

    printf("Digite o número de jogadores: ");
    scanf("%d", &n);

    int *pontuacoes = (int *)malloc(n * sizeof(int));

    printf("Digite as pontuações:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &pontuacoes[i]);
    }


    int trocou;
    for (int i = 0; i < n - 1; i++) {
        trocou = 0;
        for (int j = 0; j < n - i - 1; j++) {
            if (pontuacoes[j] < pontuacoes[j + 1]) {
                
                int temp = pontuacoes[j];
                pontuacoes[j] = pontuacoes[j + 1];
                pontuacoes[j + 1] = temp;
                trocou = 1;
            }
        }
        if (!trocou) {
            break;
        }
    }

    printf("Pontuações ordenadas: ");
    for (int i = 0; i < n; i++) {
        printf("%d ", pontuacoes[i]);
    }
    printf("\n");

    free(pontuacoes);
    return 0;
}