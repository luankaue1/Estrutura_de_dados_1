#include <stdio.h>
#include <stdlib.h>

struct Heroi {
    int saude;
    int pontuacao;
    int posX;
    int posY;
};

int main() {
    struct Heroi meuHeroi = {100, 0, 0, 0};

    printf("Estado inicial -> Saude: %d, Pontuacao: %d, PosX: %d, PosY: %d\n",
           meuHeroi.saude, meuHeroi.pontuacao, meuHeroi.posX, meuHeroi.posY);

    struct Heroi *ptrHeroi = &meuHeroi;

    ptrHeroi->saude -= 25;
    printf("Nova saude: %d\n", ptrHeroi->saude);

    ptrHeroi->pontuacao += 50;
    printf("Nova pontuacao: %d\n", ptrHeroi->pontuacao);

    ptrHeroi->posX += 10;
    ptrHeroi->posY -= 5;
    printf("Nova posicao: (%d, %d)\n", ptrHeroi->posX, ptrHeroi->posY);

    printf("Estado final -> Saude: %d, Pontuacao: %d, PosX: %d, PosY: %d\n",
           ptrHeroi->saude, ptrHeroi->pontuacao,
           ptrHeroi->posX, ptrHeroi->posY);

    return 0;
}
