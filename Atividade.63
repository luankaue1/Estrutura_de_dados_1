#include <stdio.h>

int main() {
    int placar[5] = {120, 125, 130, 142, 150};
    int novo_tempo;

    printf("Digite o novo tempo de corrida: ");
    scanf("%d", &novo_tempo);

    for (int i = 4; i >= 0; i--) {
        if (novo_tempo < placar[i]) {
            if (i < 4) {
                placar[i + 1] = placar[i];
            }
            placar[i] = novo_tempo;
        } else {
            break;
        }
    }

    printf("Placar atualizado: ");
    for (int i = 0; i < 5; i++) {
        printf("%d ", placar[i]);
    }
    printf("\n");

    return 0;
}