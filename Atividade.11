#include <stdio.h>

int main() {
    int balas[2] = {30, 50};
    int granadas[2] = {5, 10};
    int foguetes[2] = {2, 5};

    int *inventario[3];

    inventario[0] = balas;
    inventario[1] = granadas;
    inventario[2] = foguetes;

    printf("Inventario Inicial:\n");
    printf("Balas: %d\n", *inventario[0]);
    printf("Granadas: %d\n", *inventario[1]);
    printf("Foguetes: %d\n", *inventario[2]);

    for (int i = 0; i < 3; i++) {
        (*(inventario[i]))--;
    }

    printf("Inventario Apos o Uso:\n");
    printf("Balas: %d\n", *inventario[0]);
    printf("Granadas: %d\n", *inventario[1]);
    printf("Foguetes: %d\n", *inventario[2]);

    return 0;
}
